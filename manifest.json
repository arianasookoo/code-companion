{
  "manifest_version": 3,
  "name": "Code Companion",
  "version": "1.0.0",
  "description": "AI code companion: captures code from the page and helps you debug, explain, and optimize it using OpenAI.",
  "permissions": ["sidePanel", "activeTab", "scripting", "storage", "contextMenus"],
  "host_permissions": ["https://api.openai.com/*", "https://alfa-leetcode-api.onrender.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Code Companion"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
